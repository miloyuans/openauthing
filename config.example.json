{
  "app": {
    "name": "openauthing",
    "env": "development"
  },
  "http": {
    "addr": ":8080",
    "allowed_origins": [
      "http://localhost:5173"
    ]
  },
  "postgres": {
    "dsn": "postgres://openauthing@localhost:5432/openauthing?sslmode=disable"
  },
  "redis": {
    "addr": "localhost:6379"
  },
  "log": {
    "level": "info"
  },
  "session": {
    "secret": "change-me-in-local-dev-only"
  },
  "oidc": {
    "issuer": "http://localhost:8080",
    "signing_key_file": "",
    "authorization_code_ttl_seconds": 300
  },
  "saml": {
    "idp_entity_id": "",
    "certificate_file": "",
    "private_key_file": ""
  }
}
