OPENAUTHING_ENV=development
OPENAUTHING_HTTP_ADDR=:8080
OPENAUTHING_PUBLIC_URL=http://localhost:8080
OPENAUTHING_HTTP_READ_TIMEOUT=10s
OPENAUTHING_HTTP_WRITE_TIMEOUT=15s
OPENAUTHING_HTTP_IDLE_TIMEOUT=60s
OPENAUTHING_HTTP_SHUTDOWN_TIMEOUT=10s

OPENAUTHING_POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/openauthing?sslmode=disable

OPENAUTHING_REDIS_ADDR=localhost:6379
OPENAUTHING_REDIS_PASSWORD=
OPENAUTHING_REDIS_DB=0

OPENAUTHING_COOKIE_SECRET=change-me
